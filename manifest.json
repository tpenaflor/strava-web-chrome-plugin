{
  "manifest_version": 3,
  "name": "Strava Activity Analyzer",
  "version": "1.0",
  "description": "Analyze your Strava activities using AI/LLM insights",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://www.strava.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.strava.com/activities/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Strava Activity Analyzer"
  },
  "options_page": "options.html",

}